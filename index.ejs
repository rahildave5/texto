<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Texto</title>
    <link rel="stylesheet" href="/style.css">
</head>

<body>

    <form action="/chats/new" method="GET"><button>ADD CHAT</button></form>

    <% for(chat of chats){ %>
        <div class="chat">
            <p>FROM: <%= chat.from %>
            </p>
            <div class="msg">
                <p>
                    <%= chat.message %>
                </p>
            </div>
            <p>SEND TO: <%= chat.to %>
            </p>
            <p>SENT AT: <%= chat.createdAt %>
            </p>
            <hr>

        </div>
        <% } %>

</body>

</html>